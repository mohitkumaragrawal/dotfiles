# This is the configuration file for Ghostty.
#
# This template file has been automatically created at the following
# path since Ghostty couldn't find any existing config files on your system:
#
#   /home/mohit/.config/ghostty/config
#
# The template does not set any default options, since Ghostty ships
# with sensible defaults for all options. Users should only need to set
# options that they want to change from the default.
#
# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.
#
# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.

# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms


theme = Kanagawa Wave
# theme = catppuccin-mocha

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

font-family = JetBrainsMono Nerd Font

keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard

# Unbind ctrl+, in case it is mapped to a default action (like open config)
keybind = ctrl+,=unbind

# tmux-style leader on Ctrl-A.
# Double-tap Ctrl-A (or Ctrl-A then a) to send a literal Ctrl-A through.
keybind = ctrl+a=activate_key_table_once:leader
keybind = leader/
keybind = leader/ctrl+a=text:\x01
keybind = leader/a=text:\x01
keybind = leader/escape=deactivate_all_key_tables
keybind = leader/catch_all=ignore

# Tabs and windows
keybind = leader/c=new_tab
keybind = leader/n=next_tab
keybind = leader/p=previous_tab
keybind = leader/digit_1=goto_tab:1
keybind = leader/digit_2=goto_tab:2
keybind = leader/digit_3=goto_tab:3
keybind = leader/digit_4=goto_tab:4
keybind = leader/digit_5=goto_tab:5
keybind = leader/digit_6=goto_tab:6
keybind = leader/digit_7=goto_tab:7
keybind = leader/digit_8=goto_tab:8
keybind = leader/digit_9=last_tab
keybind = leader/w=new_window

# Splits
keybind = leader/minus=new_split:down
keybind = leader/shift+backslash=new_split:right
keybind = leader/|=new_split:right
keybind = leader/h=goto_split:left
keybind = leader/j=goto_split:down
keybind = leader/k=goto_split:up
keybind = leader/l=goto_split:right
keybind = leader/o=goto_split:next
keybind = leader/z=toggle_split_zoom
keybind = leader/x=close_surface
keybind = leader/shift+h=resize_split:left,30
keybind = leader/shift+j=resize_split:down,30
keybind = leader/shift+k=resize_split:up,30
keybind = leader/shift+l=resize_split:right,30
keybind = leader/e=equalize_splits

# Experimental copy mode.
# This is not full tmux parity because Ghostty still lacks keyboard-driven
# selection creation, but it gets you modal scrollback navigation and search.
keybind = leader/left_bracket=toggle_readonly
keybind = chain=activate_key_table:copy_mode

keybind = copy_mode/
keybind = copy_mode/escape=toggle_readonly
keybind = chain=deactivate_all_key_tables
keybind = copy_mode/q=toggle_readonly
keybind = chain=deactivate_all_key_tables
keybind = copy_mode/j=scroll_page_lines:1
keybind = copy_mode/k=scroll_page_lines:-1
keybind = copy_mode/ctrl+u=scroll_page_up
keybind = copy_mode/ctrl+d=scroll_page_down
keybind = copy_mode/ctrl+b=scroll_page_up
keybind = copy_mode/ctrl+f=scroll_page_down
keybind = copy_mode/g=scroll_to_top
keybind = copy_mode/shift+g=scroll_to_bottom
keybind = copy_mode/shift+h=jump_to_prompt:-1
keybind = copy_mode/shift+l=jump_to_prompt:1
keybind = copy_mode/slash=start_search
keybind = copy_mode/n=navigate_search:next
keybind = copy_mode/shift+n=navigate_search:previous
keybind = copy_mode/performable:y=copy_to_clipboard
keybind = copy_mode/performable:enter=copy_to_clipboard
keybind = copy_mode/o=write_scrollback_file:open

gtk-tabs-location = hidden
